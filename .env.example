# Copy this file to .env and fill in your values
# DO NOT commit .env to git

FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Database (used by Docker)
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=isim_website
MYSQL_USER=isim_user
MYSQL_PASSWORD=isim_password
MYSQL_ROOT_PASSWORD=root_password

DATABASE_URL=mysql://isim_user:isim_password@db:3306/isim_website

# For local dev without Docker, override:
# DATABASE_URL=mysql://root:@localhost:3306/isim_website
